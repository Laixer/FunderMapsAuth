# Base URL of the FunderMaps TS API (no trailing slash). The auth app calls
# `${VITE_FUNDERMAPS_URL}/api/auth/*`.
#   prod:  https://api.fundermaps.com
#   local: http://127.0.0.1:3000   (local API systemd unit on the dev guest)
#   test:  https://fundermaps-api-test-grcaa.ondigitalocean.app
VITE_FUNDERMAPS_URL=https://api.fundermaps.com
